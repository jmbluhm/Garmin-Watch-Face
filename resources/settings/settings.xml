<settings>
    <setting propertyKey="@Properties.foregroundColor" title="@Strings.ColorTitle">
        <settingConfig type="list">
            <listEntry value="0xCC1111">@Strings.ColorRed</listEntry>
            <listEntry value="0xFF5500">@Strings.ColorOrange</listEntry>
            <listEntry value="0xFFAA00">@Strings.ColorAmber</listEntry>
            <listEntry value="0xFFFF00">@Strings.ColorYellow</listEntry>
            <listEntry value="0x00CC00">@Strings.ColorGreen</listEntry>
            <listEntry value="0x00CCCC">@Strings.ColorCyan</listEntry>
            <listEntry value="0x3399FF">@Strings.ColorBlue</listEntry>
            <listEntry value="0xAA44FF">@Strings.ColorPurple</listEntry>
            <listEntry value="0xFF44AA">@Strings.ColorPink</listEntry>
            <listEntry value="0xFFFFFF">@Strings.ColorWhite</listEntry>
        </settingConfig>
    </setting>
</settings>
